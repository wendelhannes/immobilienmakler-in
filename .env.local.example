# ─────────────────────────────────────────────────────────────
# immobilienmakler-in.com – Umgebungsvariablen
# In Vercel unter Settings → Environment Variables setzen (Production).
# Nach Änderungen: einmal neu deployen.
# ─────────────────────────────────────────────────────────────

# ── Datenpipeline ──
APIFY_TOKEN=
ANTHROPIC_API_KEY=

# ── Sichtbarkeits-Check: Lead-Mails (Resend) ──
RESEND_API_KEY=              # resend.com → API Keys
RESEND_FROM=immobilienmakler-in.com <check@immobilienmakler-in.com>   # Absenderdomain in Resend verifizieren
REPORT_OWNER_EMAIL=          # deine Adresse: bekommt jede Report-Anfrage

# ── Sichtbarkeits-Check: Lead in Notion-Datenbank ──
NOTION_TOKEN=                # notion.so/my-integrations → Internal Integration Secret
NOTION_DATABASE_ID=          # ID der Lead-Datenbank (aus der Notion-URL)

# ── Test ohne Kosten/Versand ──
# AUDIT_DRY_RUN=1            # E-Mails werden nur geloggt (Notion läuft normal, wenn konfiguriert)
